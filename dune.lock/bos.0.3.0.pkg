(version 0.3.0)

(build
 (all_platforms
  ((action (run ocaml pkg/pkg.ml build --dev-pkg %{pkg-self:dev})))))

(depends
 (all_platforms
  (ocaml ocamlfind ocamlbuild topkg base-unix rresult astring fpath fmt logs)))

