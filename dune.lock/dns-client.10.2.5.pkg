(version 10.2.5)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs}))))))

(depends
 (all_platforms
  (dune ocaml dns randomconv domain-name mtime mirage-crypto-rng fmt ipaddr)))

(source
 (fetch
  (url
   https://github.com/mirage/ocaml-dns/releases/download/v10.2.5/dns-10.2.5.tbz)
  (checksum
   sha256=23af091a6e4c13322b7f9094577e6d72dfcd5e23c4ec00fa3520edb4ff9f5fef)))
