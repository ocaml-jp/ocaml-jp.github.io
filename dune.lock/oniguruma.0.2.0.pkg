(version 0.2.0)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs} @install))))))

(depends
 (all_platforms
  (conf-oniguruma ocaml dune dune-configurator)))

(source
 (fetch
  (url
   https://github.com/alan-j-hu/ocaml-oniguruma/releases/download/0.2.0/oniguruma-0.2.0.tbz)
  (checksum
   sha256=263660ccaa326ebe16d346e739d04b7e7929ff35eadc44e7998355bbf694c5e7)))
